<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.4jp.session-archive</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/organvm</string>
        <string>session</string>
        <string>archive</string>
        <string>--since</string>
        <string>7d</string>
    </array>

    <!-- Run every 30 minutes -->
    <key>StartInterval</key>
    <integer>1800</integer>

    <!-- Also run at login -->
    <key>RunAtLoad</key>
    <true/>

    <key>ProcessType</key>
    <string>Background</string>

    <key>Nice</key>
    <integer>15</integer>

    <!-- Kill if running longer than 5 minutes -->
    <key>ExecTimeout</key>
    <integer>300</integer>

    <key>StandardOutPath</key>
    <string>{{ .chezmoi.homeDir }}/.local/state/domus/session-archive.log</string>
    <key>StandardErrorPath</key>
    <string>{{ .chezmoi.homeDir }}/.local/state/domus/session-archive.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>{{ .chezmoi.homeDir }}</string>
        <key>ORGANVM_WORKSPACE_DIR</key>
        <string>{{ .chezmoi.homeDir }}/Workspace</string>
    </dict>

    <key>KeepAlive</key>
    <dict>
        <key>Crashed</key>
        <true/>
    </dict>

    <key>ThrottleInterval</key>
    <integer>60</integer>
</dict>
</plist>
