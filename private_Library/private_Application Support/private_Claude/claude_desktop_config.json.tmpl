{
  "mcpServers": {
    "github": {
      "command": "/opt/homebrew/bin/github-mcp-server",
      "args": ["stdio"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{{ if and (and (hasKey . "is_ci") (not .is_ci)) (lookPath "op") }}{{ onepasswordRead "op://Personal/master-org-token-110525/token" }}{{ else }}CI_REDACTED{{ end }}"
      }
    },
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/4444J99/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "desktop-app"
      ]
    },
    "filesystem": {
      "command": "/opt/homebrew/bin/npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "{{ .chezmoi.homeDir }}/Workspace"]
    },
    "sequential-thinking": {
      "command": "/opt/homebrew/bin/npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "memory": {
      "command": "/opt/homebrew/bin/npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"]
    }
  },
  "isHardwareAccelerationDisabled": false,
  "preferences": {
    "quickEntryShortcut": "off",
    "localAgentModeTrustedFolders": [
      "{{ .chezmoi.homeDir }}/Library/Mobile Documents/com~apple~CloudDocs/Documents",
      "{{ .chezmoi.homeDir }}/Library/Mobile Documents/com~apple~CloudDocs",
      "{{ .chezmoi.homeDir }}/Workspace/narratological-algorithmic-lenses"
    ],
    "coworkScheduledTasksEnabled": true,
    "sidebarMode": "chat",
    "coworkWebSearchEnabled": true
  }
}
