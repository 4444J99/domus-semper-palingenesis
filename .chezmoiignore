# OS-specific files to ignore

# Ignore macOS-specific files on non-macOS systems
{{ if ne .chezmoi.os "darwin" }}
Library/
.config/iterm2/
{{ end }}

# Ignore file-automation LaunchAgents if disabled (infrastructure agents always deploy)
{{ if not .domus_auto_enabled }}
Library/LaunchAgents/com.chezmoi.self-heal.plist
Library/LaunchAgents/com.domus.daemon.plist
Library/LaunchAgents/com.domus.sort.plist
Library/LaunchAgents/com.4jp.desktop-router.plist
Library/LaunchAgents/com.4jp.home-root-guard.plist
Library/LaunchAgents/com.4jp.downloads-tidy.plist
Library/LaunchAgents/com.4jp.naming-maintenance.plist
Library/LaunchAgents/com.4jp.agents-policy-sync.plist
Library/LaunchAgents/com.4jp.context-sync.plist
Library/LaunchAgents/com.4jp.ingestion-refresh.plist
{{ end }}

# Broken LaunchAgents — repos not yet created
Library/LaunchAgents/com.user.gmail_labeler.plist
Library/LaunchAgents/com.user.mail_automation.plist

# Ignore Linux-specific files on non-Linux systems
{{ if ne .chezmoi.os "linux" }}
.config/i3/
.config/sway/
{{ end }}

# Ignore work-specific files on personal machines
{{ if not .is_work }}
work_scripts/
{{ end }}

# Ignore AWS credentials unless explicitly enabled
# Set has_aws_credentials = true in ~/.config/chezmoi/chezmoi.toml to enable
{{ if not (hasKey . "has_aws_credentials") }}
.config/aws/credentials
{{ else if not .has_aws_credentials }}
.config/aws/credentials
{{ end }}

# Always ignore these
.DS_Store
*.swp
*.swo
*~

# Documentation files in config dirs (don't apply to home directory)
.config/zsh/completions/README.md

# Repository files (don't apply to home directory)
.gitignore
.github/
.shellcheckrc
.yamllint.yml
.pre-commit-config.yaml
.gitleaks.toml
justfile
.serena/
tests/

# Python bytecode (generated at runtime)
**/__pycache__/
*.pyc

# Repository documentation (don't apply to home directory)
README.md
CHANGELOG.md
BOOTSTRAP.md
BACKUP_STRATEGY.md
docs/
.claude/README.md
1PASSWORD_SETUP.md
PLUGINS.md
DOTFILES_CLEANUP.md

# Agent runtime state (managed by agent tools, not chezmoi)
_agents/cache/
_agents/state/
_agents/log/
_agents/lab/.venv/
projects/
_registry/

# Claude session data — managed by Claude Code, preserved via per-project archival
.claude/projects/*/*.jsonl
.claude/projects/*/[0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f]-*
.claude/projects/*/memory/
.claude/projects/*/sessions-index.json
