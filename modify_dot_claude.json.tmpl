#!/usr/bin/env python3
"""
Chezmoi modify script for ~/.claude.json
Preserves existing config, ensures valid JSON with trailing newline.
Injects managed MCP servers and removes hardcoded secrets from manually-added ones.
"""
import json
import os
import sys

try:
    config = json.load(sys.stdin)
except json.JSONDecodeError:
    config = {}

# Ensure mcpServers exists
if "mcpServers" not in config:
    config["mcpServers"] = {}

HOME = "{{ .chezmoi.homeDir }}"

# --- Managed MCP servers (injected by chezmoi, secrets from env) ---

# Conductor MCP server (cognitive service dispatch, fleet routing, cross-verification)
CONDUCTOR_BASE = f"{HOME}/Workspace/organvm-iv-taxis/tool-interaction-design"
config["mcpServers"]["conductor"] = {
    "command": f"{CONDUCTOR_BASE}/.venv/bin/python3",
    "args": [f"{CONDUCTOR_BASE}/mcp_server.py"],
    "cwd": CONDUCTOR_BASE,
}

# Voice Scorer MCP server (voice governance, scoring, drift detection)
VOX_BASE = f"{HOME}/Workspace/organvm-iv-taxis/vox--architectura-gubernatio"
config["mcpServers"]["voice-scorer"] = {
    "command": f"{VOX_BASE}/.venv/bin/python3",
    "args": [f"{VOX_BASE}/src/vox/mcp_server.py"],
    "cwd": VOX_BASE,
}

# GitHub MCP server — token from GITHUB_PERSONAL_ACCESS_TOKEN env var (set by secrets.zsh)
gh_token = os.environ.get("GITHUB_PERSONAL_ACCESS_TOKEN", "")
if gh_token:
    config["mcpServers"]["github"] = {
        "command": "docker",
        "args": ["run", "-i", "--rm", "-e", "GITHUB_PERSONAL_ACCESS_TOKEN",
                 "ghcr.io/github/github-mcp-server"],
        "env": {"GITHUB_PERSONAL_ACCESS_TOKEN": gh_token},
    }

# Neon MCP server — token from NEON_API_KEY env var (set by secrets.zsh)
neon_key = os.environ.get("NEON_API_KEY", "")
if neon_key:
    config["mcpServers"]["Neon"] = {
        "type": "http",
        "url": "https://mcp.neon.tech/mcp",
        "headers": {"Authorization": f"Bearer {neon_key}"},
    }

print(json.dumps(config, indent=2, ensure_ascii=False), end="")
