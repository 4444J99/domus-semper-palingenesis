#!/usr/bin/env python3
"""
Chezmoi modify script for ~/.claude.json
Preserves existing config, ensures valid JSON with trailing newline.
Injects Conductor MCP server for system-wide dispatch capabilities.
"""
import json
import sys

try:
    config = json.load(sys.stdin)
except json.JSONDecodeError:
    config = {}

# Ensure mcpServers exists
if "mcpServers" not in config:
    config["mcpServers"] = {}

# Inject Conductor MCP server (cognitive service dispatch, fleet routing, cross-verification)
CONDUCTOR_BASE = "{{ .chezmoi.homeDir }}/Workspace/organvm-iv-taxis/tool-interaction-design"
config["mcpServers"]["conductor"] = {
    "command": f"{CONDUCTOR_BASE}/.venv/bin/python3",
    "args": [f"{CONDUCTOR_BASE}/mcp_server.py"],
    "cwd": CONDUCTOR_BASE,
}

# Inject Voice Scorer MCP server (voice governance, scoring, drift detection)
VOX_BASE = "{{ .chezmoi.homeDir }}/Workspace/organvm-iv-taxis/vox--architectura-gubernatio"
config["mcpServers"]["voice-scorer"] = {
    "command": f"{VOX_BASE}/.venv/bin/python3",
    "args": ["-m", "vox.mcp_server"],
    "cwd": VOX_BASE,
}

print(json.dumps(config, indent=2, ensure_ascii=False), end="")
