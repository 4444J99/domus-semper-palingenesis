#!/usr/bin/env python3
"""
Chezmoi modify script for ~/.claude.json
Preserves existing config, ensures valid JSON with trailing newline.
MCP servers are managed by Claude Code plugins and MCP_DOCKER gateway.
"""
import json
import sys

try:
    config = json.load(sys.stdin)
except json.JSONDecodeError:
    config = {}

print(json.dumps(config, indent=2, ensure_ascii=False) + "\n", end="")
