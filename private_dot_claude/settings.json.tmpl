{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "find {{ .chezmoi.homeDir }}/.claude/plugins/cache -name '*.sh' -path '*/hooks*' -exec chmod +x {} + 2>/dev/null; true"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"SessionStart\",\"additionalContext\":\"MEMORY HYGIENE (session start):\\n\u2022 Memory = hypothesis, not fact. Any state recalled from a previous session (file paths, branch names, repo state, PR status) MUST be verified against current disk state before acting.\\n\u2022 Stale diagnoses produce false IRF entries and real damage. Verify first, act second.\\n\u2022 Cross-session claims from other agent sessions must also be independently verified.\"}}'",
            "statusMessage": "Memory hygiene check..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/session-atoms-context.sh 2>/dev/null; true",
            "timeout": 15,
            "statusMessage": "Loading atom status..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.local/bin/session-context \"$(pwd)\" 2>/dev/null | python3 -c \"import sys,json; ctx=sys.stdin.read().strip(); print(json.dumps({'hookSpecificOutput':{'hookEventName':'SessionStart','additionalContext':ctx}}))\" 2>/dev/null; true",
            "timeout": 10,
            "statusMessage": "Loading contextual briefing..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.local/bin/resolve-audit --hook 2>/dev/null; true",
            "timeout": 10,
            "statusMessage": "Resolver audit..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "if": "Bash(gh pr comment *)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"OUTBOUND ACTION PREFLIGHT \u2014 Mandatory before posting PR comment:\\n1. AUDIT: Did you read the full PR thread (comments, reviews, CI status, bot instructions) BEFORE composing this comment?\\n2. PROTOCOLS: Did you check {{ .organvm_dir }}/orchestration-start-here/contrib_engine/outreach_protocol.md?\\n3. SEQUENCE: If multi-step, are all steps planned and is this the correct order?\\n4. EDIT-NOT-ERRATA: Should you edit an existing comment instead of appending?\\n5. THREAD-STATE: Does this comment address what the thread actually needs?\\n6. CADENCE: Is this part of a cross-repo burst (<90s between repos)? Stagger if so \u2014 rapid multi-repo posting signals bot behavior.\\n7. UPSTREAM RULES: If external/upstream repo, did you read its CONTRIBUTING.md? We are guests.\"}}'",
            "statusMessage": "Outbound action preflight..."
          },
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/comment-cadence-tracker.sh 2>/dev/null; true",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(gh issue comment *)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"OUTBOUND ACTION PREFLIGHT \u2014 Mandatory before posting issue comment:\\n1. AUDIT: Did you read the full issue thread (comments, assignees, labels) BEFORE composing this comment?\\n2. PROTOCOLS: Did you check {{ .organvm_dir }}/orchestration-start-here/contrib_engine/outreach_protocol.md?\\n3. SEQUENCE: If multi-step, are all steps planned and is this the correct order?\\n4. EDIT-NOT-ERRATA: Should you edit an existing comment instead of appending?\\n5. THREAD-STATE: Does this comment address what the issue actually needs?\\n6. CADENCE: Is this part of a cross-repo burst (<90s between repos)? Stagger if so.\\n7. UPSTREAM RULES: If external/upstream repo, did you read its CONTRIBUTING.md? We are guests.\"}}'",
            "statusMessage": "Outbound action preflight..."
          },
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/comment-cadence-tracker.sh 2>/dev/null; true",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(gh pr review *)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"OUTBOUND ACTION PREFLIGHT \u2014 Mandatory before submitting PR review:\\n1. AUDIT: Did you read the full PR diff, existing reviews, and CI status?\\n2. PROTOCOLS: Did you check workspace contribution protocols?\\n3. SEQUENCE: Is this review part of a larger action sequence? Plan atomically.\\n4. THREAD-STATE: Does the review address what the PR actually needs?\\n5. CADENCE: Part of a cross-repo burst? Stagger \u2014 90s minimum between repos.\\n6. UPSTREAM RULES: Read CONTRIBUTING.md for this repo first. We are guests.\"}}'",
            "statusMessage": "Outbound action preflight..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(*git push*--force*)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"DESTRUCTION GUARD \u2014 Force Push:\\n\u2022 STOP. Force-push rewrites remote history \u2014 irreversible for collaborators.\\n\u2022 Verify: (1) Is this a personal/feature branch, NOT main/master? (2) Are there NO collaborators on this branch? (3) Is this explicitly intentional, not habitual?\\n\u2022 If pushing to main with --force: ABORT. Use --force-with-lease as minimum safety.\"}}'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(*git push* -f *)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"DESTRUCTION GUARD \u2014 Force Push (-f):\\n\u2022 Same risk as --force. Rewrites remote history irreversibly.\\n\u2022 Verify: personal/feature branch only, no collaborators, explicitly intentional.\"}}'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(*git branch*-D*)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"DESTRUCTION GUARD \u2014 Hard Branch Delete (-D):\\n\u2022 -D ignores unmerged state. This branch may contain unmerged work.\\n\u2022 Verify: (1) Fully merged or intentionally abandoned? (2) All work backed up remotely?\\n\u2022 Use -d instead for safe delete (fails if unmerged).\"}}'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(*git push*main*)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"WORKFLOW GUARD \u2014 Direct Push to Main:\\n\u2022 Most repos use branch + PR workflow. Direct main pushes bypass review.\\n\u2022 Verify: (1) Intentional (e.g., domus autoCommit is expected)? (2) Branch protection rules in place?\\n\u2022 If unsure: use a feature branch and PR instead.\"}}'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(*gh issue close*)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"GUARD \u2014 Issue Close:\\n\u2022 Closing issues requires explicit permission (organvm-engine feedback: never close without user authorization).\\n\u2022 Verify: (1) Did the user explicitly ask to close this issue? (2) Is it actually resolved, not just worked around?\"}}'"
          }
        ]
      },
      {
        "matcher": "Write",
        "if": "Write(*registry*.json)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"DATA INTEGRITY \u2014 Registry Write:\\n\u2022 Registry files are the single source of truth for all repo metadata (2200+ lines).\\n\u2022 ADDITIVE-ONLY: Did you Read this file first? Are you making a targeted addition, not replacing it?\\n\u2022 If generating from scratch: STOP. Use Edit for targeted changes. Wholesale replacement corrupts the registry.\"}}'"
          }
        ]
      },
      {
        "matcher": "Write",
        "if": "Write(*IRF*.md)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"DATA INTEGRITY \u2014 IRF Write:\\n\u2022 IRF is the universal work registry. Entries are append-only \u2014 never replace existing rows.\\n\u2022 Verify: (1) Did you Read the file first? (2) Appending new items only, not overwriting completed items?\"}}'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(*rm*fetch*)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"DATA INTEGRITY \u2014 Deleting Fetched Data:\\n\u2022 Rate-limited fetched data must NEVER be deleted (conversation-corpus project rule).\\n\u2022 Verify: Is this rate-limited API data? If yes: abort. Log the vacuum, do not delete the source.\"}}'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(*op read*)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"1PASSWORD DISCIPLINE:\\n\u2022 Cache this secret value immediately after reading \u2014 store in a variable.\\n\u2022 ONE op read per secret per session is the limit. Do not call op read again for the same path.\"}}'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(*op item get*)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"1PASSWORD DISCIPLINE:\\n\u2022 Cache this result immediately. ONE op item get per secret per session \u2014 no repeat calls.\"}}'"
          }
        ]
      },
      {
        "matcher": "Write",
        "if": "Write(*.plist*)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"HARD BLOCK \u2014 LaunchAgent Creation:\\n\u2022 NEVER create or deploy LaunchAgents. Every single LaunchAgent has caused machine freezes, CPU thrash, or system instability.\\n\u2022 The operational model is ON-DEMAND CLI ONLY. Scripts in ~/.local/bin/ can be run manually.\\n\u2022 If you need scheduled execution: use cron (not launchd), or better yet, make it event-driven.\\n\u2022 This is a UNIVERSAL RULE from feedback_no_launchagents.md. Do not proceed.\"}}'"
          }
        ]
      },
      {
        "matcher": "Write",
        "if": "Write(*LaunchAgent*)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"HARD BLOCK \u2014 LaunchAgent creation is forbidden. Every incident froze the machine. On-demand CLI only.\"}}'"
          }
        ]
      },
      {
        "matcher": "Write",
        "if": "Write(*plans/*.md)",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.local/bin/substrate-check gate vacuum --target \"$CLAUDE_TOOL_ARG_FILE_PATH\" --hook 2>/dev/null; true",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "if": "Write(*/.claude/projects/*/memory/*)",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.local/bin/domus-memory-sync \"$CLAUDE_TOOL_ARG_FILE_PATH\" &",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write",
        "if": "Write(*/.claude/plans/*)",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.local/bin/domus-memory-sync \"$CLAUDE_TOOL_ARG_FILE_PATH\" &",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write",
        "if": "Write(**/plans/**)",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/plan-persistence-check.sh 2>/dev/null; true",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"Stop\",\"additionalContext\":\"SESSION HYGIENE (always-on):\\n\u2022 CLOSE GATE: Ending session? Run 13-step protocol (meta-organvm/memory/feedback_close_protocol.md)\\n\u2022 PARITY: local:remote=1:1 \u2014 git status clean, all commits pushed, memory backed up\\n\u2022 VACUUM: N/A is never a resting state \u2014 convert to named IRF items with IDs\\n\u2022 ADDITIVE: rules only accumulate \u2014 new rules amend old ones, never replace\"}}'",
            "statusMessage": "Session hygiene..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 {{ .chezmoi.homeDir }}/.claude/hooks/execution-discipline.py",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/substrate-atomize-hook.sh",
            "timeout": 3
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.local/bin/anti-paste-guard",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/session-parity-check.sh 2>/dev/null; true",
            "timeout": 15,
            "statusMessage": "Checking repo parity..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "git -C \"$(pwd)\" log \"origin/$(git -C \"$(pwd)\" branch --show-current 2>/dev/null)..HEAD\" --oneline 2>/dev/null | head -5 > \"/tmp/claude-session-$(date +%Y%m%d-%H%M%S).unpushed.log\" 2>/dev/null; true",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/session-prompt-capture.sh 2>/dev/null; true",
            "timeout": 30
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.local/bin/substrate-check verify-close --hook 2>/dev/null; true",
            "timeout": 10,
            "statusMessage": "Substrate verify-close..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.local/bin/insights-snapshot --only-if-newer --quiet 2>/dev/null; true",
            "timeout": 15,
            "statusMessage": "Insights snapshot..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": {{ printf "bash -c '%s'" (replace "'" "'\\''" (include "private_dot_claude/executable_statusline-command.sh")) | toJson }}
  },
  "enabledPlugins": {
    "atlassian@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "firebase@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "linear@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "serena@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "stripe@claude-plugins-official": true,
    "supabase@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "warp@claude-code-warp": true
  },
  "extraKnownMarketplaces": {
    "claude-code-warp": {
      "source": {
        "source": "github",
        "repo": "warpdotdev/claude-code-warp"
      }
    }
  },
  "effortLevel": "high",
  "autoDreamEnabled": true,
  "skipDangerousModePermissionPrompt": true
}
