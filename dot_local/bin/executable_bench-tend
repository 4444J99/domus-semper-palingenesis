#!/usr/bin/env python3
"""bench-tend — bounded sweep that ages out stale in-flight dispatches.

Walks the journal; for any record with op='dispatched' (or status='dispatched')
older than the threshold without a matching update, append an 'aged_out'
record. This is the maintenance pass that replaces the heartbeat-daemon
requirement of IRF-SYS-074 Phase 5.

Modes:
  default   thorough sweep, 1h threshold for stale dispatches
  --lazy    quick sweep called from the bench entrypoint (fast, 5s budget)

Plan: ~/.claude/plans/design-every-winding-turning-valiant-thompson.md
"""

from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
import time
from datetime import datetime, timezone
from pathlib import Path

STATE_DIR = Path(os.environ.get("BENCH_STATE_DIR", os.path.expanduser("~/.local/state/bench-fabric")))
JOURNAL = STATE_DIR / "journal.jsonl"
JOURNAL_BIN = os.environ.get("BENCH_JOURNAL_BIN", "bench-journal")


def parse_ts(ts: str) -> float:
    try:
        dt = datetime.strptime(ts, "%Y-%m-%dT%H:%M:%SZ").replace(tzinfo=timezone.utc)
        return dt.timestamp()
    except (ValueError, TypeError):
        return 0.0


def latest_status_per_id(records: list[dict]) -> dict[str, dict]:
    """Walk records in order; for each id, keep the latest status."""
    latest: dict[str, dict] = {}
    for r in records:
        rid = r.get("id")
        if not rid:
            continue
        latest[rid] = r
    return latest


def append_update(record_id: str, fields: dict) -> None:
    args = [JOURNAL_BIN, "update", record_id]
    for k, v in fields.items():
        args.extend(["--field", f"{k}={json.dumps(v)}"])
    subprocess.run(args, capture_output=True, text=True, check=False)


def sweep(threshold_seconds: int, budget_seconds: float, dry_run: bool) -> dict:
    if not JOURNAL.exists():
        return {"records_walked": 0, "aged": 0, "skipped": 0}
    records = []
    for line in JOURNAL.read_text(encoding="utf-8").splitlines():
        if not line.strip():
            continue
        try:
            records.append(json.loads(line))
        except json.JSONDecodeError:
            continue

    latest = latest_status_per_id(records)
    cutoff = time.time() - threshold_seconds
    started = time.time()
    aged = 0
    skipped = 0

    for rid, rec in latest.items():
        if time.time() - started > budget_seconds:
            skipped = len(latest) - aged
            break
        status = rec.get("status")
        if status not in ("dispatched", "in_flight"):
            continue
        ts = parse_ts(rec.get("ts", ""))
        if ts >= cutoff:
            continue
        if dry_run:
            aged += 1
            continue
        append_update(rid, {
            "status": "aged_out",
            "op": "aged",
            "stale_seconds": int(time.time() - ts),
            "tend_threshold_seconds": threshold_seconds,
        })
        aged += 1

    return {"records_walked": len(records), "ids_tracked": len(latest), "aged": aged, "skipped": skipped}


def main() -> int:
    p = argparse.ArgumentParser(prog="bench-tend", description=__doc__.splitlines()[0])
    p.add_argument("--lazy", action="store_true", help="Quick sweep, 5s budget")
    p.add_argument("--threshold", type=int, default=3600, help="Stale threshold in seconds (default 1h)")
    p.add_argument("--dry-run", action="store_true")
    p.add_argument("--json", action="store_true")
    args = p.parse_args()

    budget = 5.0 if args.lazy else 60.0
    threshold = 60 if args.lazy else args.threshold

    result = sweep(threshold, budget, args.dry_run)
    if args.json:
        print(json.dumps(result, sort_keys=True))
    else:
        print(f"bench-tend walked={result['records_walked']} tracked={result['ids_tracked']} aged={result['aged']} skipped={result['skipped']}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
