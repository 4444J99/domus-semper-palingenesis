#!/usr/bin/env bash
# domus-context-sync — run organvm context sync when registry changes
# Called by com.4jp.context-sync LaunchAgent (WatchPaths on registry-v2.json)
set -euo pipefail

LOGDIR="${HOME}/.local/state/domus"
LOGFILE="${LOGDIR}/context-sync.log"
LOCKFILE="${LOGDIR}/context-sync.lock"
REGISTRY="${HOME}/Workspace/meta-organvm/organvm-corpvs-testamentvm/registry-v2.json"

mkdir -p "${LOGDIR}"

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >>"${LOGFILE}"; }

# Prevent concurrent runs
if [[ -f "${LOCKFILE}" ]]; then
  pid=$(cat "${LOCKFILE}" 2>/dev/null || echo "")
  if [[ -n "${pid}" ]] && kill -0 "${pid}" 2>/dev/null; then
    log "SKIP: already running (pid ${pid})"
    exit 0
  fi
  rm -f "${LOCKFILE}"
fi
echo $$ >"${LOCKFILE}"
trap 'rm -f "${LOCKFILE}"' EXIT

# Guard: registry must exist
if [[ ! -f "${REGISTRY}" ]]; then
  log "ERROR: registry not found at ${REGISTRY}"
  exit 1
fi

# Guard: organvm must be available
if ! command -v organvm &>/dev/null; then
  log "ERROR: organvm not in PATH"
  exit 1
fi

log "START: context sync triggered"

# Run context sync with --write (not dry-run)
if organvm context sync --write >>"${LOGFILE}" 2>&1; then
  log "DONE: context sync completed successfully"
else
  exit_code=$?
  log "ERROR: context sync failed (exit ${exit_code})"
  exit "${exit_code}"
fi
