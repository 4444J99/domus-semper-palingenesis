#!/usr/bin/env bash
set -euo pipefail

# domus-memory-sync — Persist Claude memory and plan files to remote via chezmoi.
#
# Usage:
#   domus-memory-sync <filepath>    Sync a single file
#   domus-memory-sync --all         Sync all changed memory/plan files
#
# Principle: [(local):(remote)={1:1}]
# An unsigned commit on remote beats a signed commit that only exists locally.
#
# Performance: uses a last-sync timestamp so only recently changed files are
# processed, and batches chezmoi add into a single call to avoid per-file lock
# contention that blocks chezmoi diff/apply.

CHEZMOI_SOURCE="$(chezmoi source-path 2>/dev/null)"
readonly CHEZMOI_SOURCE
readonly STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/domus"
readonly LOG_FILE="$STATE_DIR/memory-sync.log"
readonly UNSIGNED_FLAG="$STATE_DIR/unsigned-commits-pending"
readonly LOCK_FILE="$STATE_DIR/memory-sync.lock"
readonly LAST_SYNC="$STATE_DIR/memory-sync.last"

log() { printf '%s %s\n' "$(date +%Y-%m-%dT%H:%M:%S)" "$*" >>"$LOG_FILE"; }

mkdir -p "$STATE_DIR"

# Prevent concurrent runs
if [[ -f "$LOCK_FILE" ]]; then
  lock_age=$(($(date +%s) - $(stat -f %m "$LOCK_FILE" 2>/dev/null || echo 0)))
  if ((lock_age < 120)); then
    log "SKIP: lock held (age ${lock_age}s)"
    exit 0
  fi
  log "WARN: stale lock (age ${lock_age}s), removing"
  rm -f "$LOCK_FILE"
fi
trap 'rm -f "$LOCK_FILE"' EXIT
touch "$LOCK_FILE"

if [[ -z "$CHEZMOI_SOURCE" ]]; then
  log "ERROR: chezmoi source-path not found"
  exit 1
fi

# Yield to interactive chezmoi operations (apply, diff, edit, update, doctor)
if pgrep -f 'chezmoi (apply|diff|edit|update|doctor)' >/dev/null 2>&1; then
  log "SKIP: chezmoi operation in progress — yielding"
  exit 0
fi

# Determine files to sync
files_to_add=()

if [[ "${1:-}" == "--all" ]]; then
  # Use last-sync timestamp so only files changed since last successful sync
  # are processed — not the entire 700+ file corpus every time.
  newer_ref="$LAST_SYNC"
  [[ -f "$newer_ref" ]] || newer_ref="$LOCK_FILE"

  while IFS= read -r f; do
    [[ -f "$f" ]] && files_to_add+=("$f")
  done < <(
    find "$HOME/.claude/projects" -path "*/memory/*.md" -newer "$newer_ref" 2>/dev/null
    find "$HOME/.claude/plans" -name "*.md" -newer "$newer_ref" 2>/dev/null
  )
elif [[ -n "${1:-}" && -f "$1" ]]; then
  files_to_add+=("$1")
else
  log "USAGE: domus-memory-sync <filepath> | --all"
  exit 1
fi

if [[ ${#files_to_add[@]} -eq 0 ]]; then
  log "SKIP: no files to sync"
  touch "$LAST_SYNC"
  exit 0
fi

log "SYNC: ${#files_to_add[@]} files to add"

# Batch chezmoi add — single lock acquisition instead of per-file loop.
# chezmoi add accepts multiple targets and handles them in one pass.
if chezmoi add "${files_to_add[@]}" 2>>"$LOG_FILE"; then
  log "ADD: ${#files_to_add[@]} files (batch)"
else
  log "WARN: chezmoi add had errors (partial success possible)"
fi

# Commit and push from chezmoi source
cd "$CHEZMOI_SOURCE"

# Stage any changes chezmoi add created
git add -A 2>>"$LOG_FILE"

# Check if there's anything to commit
if git diff --cached --quiet 2>/dev/null; then
  log "SKIP: nothing staged after chezmoi add"
  touch "$LAST_SYNC"
  exit 0
fi

timestamp="$(date +%Y-%m-%dT%H:%M:%S)"
count=${#files_to_add[@]}

# Try signed commit first
if git commit -m "memory: auto-persist $timestamp" 2>>"$LOG_FILE"; then
  log "COMMIT: signed ($count files)"
else
  # Signing failed — fall back to unsigned
  if git commit --no-gpg-sign -m "memory: auto-persist (UNSIGNED) $timestamp" 2>>"$LOG_FILE"; then
    log "COMMIT: unsigned ($count files) — 1Password unavailable"
    echo "$timestamp" >>"$UNSIGNED_FLAG"
  else
    log "ERROR: commit failed entirely"
    exit 1
  fi
fi

# Push to remote
if git push 2>>"$LOG_FILE"; then
  log "PUSH: success"
else
  log "ERROR: push failed — will retry on next sync"
  exit 1
fi

touch "$LAST_SYNC"
log "DONE: $count files synced"
