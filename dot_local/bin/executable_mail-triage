#!/usr/bin/env python3
# ruff: noqa: E501
"""
Triage unread INBOX messages into SPAM/NOISE/HUMAN/ACTION mailboxes.

Uses Mail.app's AppleScript interface to read unread messages from the
Gmail INBOX, classifies each by sender and content heuristics, and moves
them to [Gmail]/Triage/* mailboxes (which sync as Gmail labels).

Dry run by default; pass --apply to actually move messages.
Logs to ~/.local/state/domus/mail-triage.log.
"""
from __future__ import annotations

import argparse
import logging
import re
import subprocess
import sys
from datetime import datetime
from pathlib import Path

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

MAIL_ACCOUNT = "padavano.anthony@gmail"
MAILBOX_INBOX = "INBOX"
FIELD_SEP = "|||"
RECORD_SEP = "^^^"

LOG_DIR = Path.home() / ".local" / "state" / "domus"
LOG_FILE = LOG_DIR / "mail-triage.log"

# Gmail labels exposed as IMAP mailboxes
TRIAGE_MAILBOXES = [
    "Triage/Spam",
    "Triage/Noise",
    "Triage/Human",
    "Triage/Action",
    "Triage/Action/Today",
    "Triage/Action/This-Week",
    "Triage/Action/Someday",
]

