#!/usr/bin/env python3
"""insights-drift — multi-snapshot trajectory + narrative-shift report.

Walks every snapshot in chronological order and renders:
  1. Stat trajectory table (sessions, messages, commits, window edges, …)
  2. Narrative-phrase transitions (key_pattern, fun_ending_headline) — only
     printed when the phrase actually changed between consecutive snapshots
  3. Project-area churn (renames / additions / removals between consecutive snapshots)

Read-only. No deletion, no archive. Snapshots accumulate.
"""
from __future__ import annotations
import argparse
import datetime as dt
import difflib
import json
import pathlib
import sys

SNAPDIR = pathlib.Path.home() / ".claude" / "usage-data" / "snapshots"

TRACKED_STATS = [
    "sessions_analyzed",
    "sessions_total",
    "messages",
    "commits",
    "files",
    "lines",
    "days",
    "msgs_per_day",
]


def load_all(since: dt.date | None) -> list[tuple[pathlib.Path, dict]]:
    out: list[tuple[pathlib.Path, dict]] = []
    if not SNAPDIR.is_dir():
        return out
    for d in sorted(SNAPDIR.glob("*")):
        if not d.is_dir():
            continue
        mf = d / "manifest.json"
        if not mf.exists():
            continue
        m = json.loads(mf.read_text())
        if since:
            try:
                stamp = dt.datetime.strptime(d.name, "%Y-%m-%dT%H%M").date()
                if stamp < since:
                    continue
            except ValueError:
                pass
        out.append((d, m))
    return out


def stat_trajectory(rows: list[tuple[pathlib.Path, dict]]) -> None:
    print("## Stat trajectory")
    print()
    headers = ["snapshot"] + TRACKED_STATS + ["window"]
    widths = [len(h) for h in headers]
    body: list[list[str]] = []
    for d, m in rows:
        s = m.get("stats", {})
        w = m.get("window", {})
        win = (
            f"{w.get('start','?')}→{w.get('end','?')}({w.get('days','?')}d)"
            if w
            else "?"
        )
        row = [d.name] + [str(s.get(k, "?")) for k in TRACKED_STATS] + [win]
        widths = [max(wid, len(c)) for wid, c in zip(widths, row)]
        body.append(row)
    fmt = "  ".join(f"{{:<{w}}}" for w in widths)
    print(fmt.format(*headers))
    print(fmt.format(*["-" * w for w in widths]))
    for row in body:
        print(fmt.format(*row))
    print()


def narrative_transitions(rows: list[tuple[pathlib.Path, dict]]) -> None:
    print("## Narrative transitions")
    print()
    if len(rows) < 2:
        print("(need at least 2 snapshots)")
        return
    fields = [("key_pattern", "Key pattern"), ("fun_ending_headline", "Fun ending")]
    for field, label in fields:
        print(f"### {label}")
        prev_val = None
        prev_name = None
        any_change = False
        for d, m in rows:
            v = m.get(field)
            if v is None:
                continue
            if prev_val is None:
                print(f"  {d.name}: {v}")
                prev_val, prev_name = v, d.name
                continue
            if v != prev_val:
                any_change = True
                sim = difflib.SequenceMatcher(None, prev_val, v).ratio()
                print(f"  {prev_name} → {d.name}  (similarity {sim:.2f})")
                print(f"    THEN: {prev_val}")
                print(f"    NOW : {v}")
                prev_val, prev_name = v, d.name
        if not any_change:
            print(f"  (unchanged across {len(rows)} snapshots)")
        print()


def area_churn(rows: list[tuple[pathlib.Path, dict]]) -> None:
    print("## Project-area churn")
    print()
    if len(rows) < 2:
        print("(need at least 2 snapshots)")
        return
    for i in range(1, len(rows)):
        a_dir, a_m = rows[i - 1]
        b_dir, b_m = rows[i]
        a_names = {x["name"] for x in a_m.get("areas", [])}
        b_names = {x["name"] for x in b_m.get("areas", [])}
        if a_names == b_names:
            print(f"  {a_dir.name} → {b_dir.name}: areas unchanged")
            continue
        added = sorted(b_names - a_names)
        removed = sorted(a_names - b_names)
        print(f"  {a_dir.name} → {b_dir.name}:")
        for n in removed:
            print(f"    - {n}")
        for n in added:
            print(f"    + {n}")
    print()


def main() -> int:
    p = argparse.ArgumentParser(description=__doc__.splitlines()[0])
    p.add_argument(
        "--since",
        help="ISO date (YYYY-MM-DD); only consider snapshots on or after",
    )
    p.add_argument(
        "--narrative-only",
        action="store_true",
        help="skip stat trajectory + area churn",
    )
    args = p.parse_args()
    since = dt.date.fromisoformat(args.since) if args.since else None
    rows = load_all(since)
    if not rows:
        sys.exit("insights-drift: no snapshots found")
    print(f"# insights-drift  ({len(rows)} snapshots)")
    print()
    if not args.narrative_only:
        stat_trajectory(rows)
        area_churn(rows)
    narrative_transitions(rows)
    return 0


if __name__ == "__main__":
    sys.exit(main())
