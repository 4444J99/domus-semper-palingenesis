#!/usr/bin/env python3
"""corpus-extract — pull tagged artifacts (e.g. <brainstorm>, [IDEA])
from a prompt corpus or raw JSONL history.

Usage:
    corpus-extract --pattern TAG [--in PATH] [--out DIR]

Defaults:
    --in:  ~/.claude/plans/2026-04-28-ark-universal.md
    --out: ./extractions/

Built to reach back into the substrate and salvage lost gems.
"""
from __future__ import annotations

import argparse
import re
import sys
from pathlib import Path

def extract_blocks(text: str, tag: str) -> list[str]:
    esc = re.escape(tag)
    delim_patterns = [
        (rf"<{esc}[^>]*>(.*?)</{esc}>", re.DOTALL | re.IGNORECASE),
        (rf"\[{esc}\][\s\n]*(.*?)[\s\n]*\[/{esc}\]", re.DOTALL | re.IGNORECASE),
        (rf"\[{esc}\][\s\n]*(.*?)(?=\n\s*\[|$)", re.DOTALL | re.IGNORECASE),
    ]
    header_pattern = (
        rf"^#{{1,6}}\s+(?:[IVX]+\.\s+)?(?:CORE\s+)?{esc}\b[^\n]*\n(.*?)(?=^#{{1,6}}\s|\Z)",
        re.DOTALL | re.IGNORECASE | re.MULTILINE,
    )
    id_pattern = (rf"^id:\s*{esc}__([^\s\n]+)", re.MULTILINE | re.IGNORECASE)

    blocks: list[str] = []
    for p, flags in delim_patterns + [header_pattern, id_pattern]:
        blocks.extend(re.findall(p, text, flags))
    return [b.strip() for b in blocks if b.strip()]

def main() -> int:
    ap = argparse.ArgumentParser(description=__doc__)
    ap.add_argument("--pattern", required=True, help="tag to search for (e.g. brainstorm)")
    ap.add_argument("--in-file", help="input file (default: last generated Ark)")
    ap.add_argument("--out-dir", default="./extractions", help="output directory")
    args = ap.parse_args()

    in_path = Path(args.in_file or "~/.claude/plans/2026-04-28-ark-universal.md").expanduser()
    if not in_path.exists():
        print(f"Error: input file {in_path} not found", file=sys.stderr)
        return 1

    content = in_path.read_text()
    blocks = extract_blocks(content, args.pattern)
    
    if not blocks:
        print(f"No blocks found matching '{args.pattern}'", file=sys.stderr)
        return 0

    out_dir = Path(args.out_dir).expanduser()
    out_dir.mkdir(parents=True, exist_ok=True)
    
    print(f"Extracted {len(blocks)} blocks for '{args.pattern}'", file=sys.stderr)
    for i, block in enumerate(blocks, 1):
        # Generate a slug from the first few words
        first_line = block.splitlines()[0]
        slug = re.sub(r"[^a-z0-9]+", "-", first_line.lower())[:30].strip("-")
        filename = f"{args.pattern}-{i:02d}-{slug}.md"
        dest = out_dir / filename
        dest.write_text(block)
        print(f"  -> {dest}", file=sys.stderr)

    return 0

if __name__ == "__main__":
    sys.exit(main())
