#!/usr/bin/env python3
"""bench-preflight — probe bench agents for reachability.

For each known agent, runs a tiniest-possible dispatch ("respond PING")
and classifies the outcome. Cache TTL 10 min at
$BENCH_STATE_DIR/preflight/<agent>.json.

Exit codes: 0 = all green, 1 = at least one yellow, 2 = at least one red,
            3 = no agents probed successfully (binary missing, etc.).

When given an agent name, returns that agent's status in the same scheme.

Plan: ~/.claude/plans/design-every-winding-turning-valiant-thompson.md
"""

from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import subprocess
import sys
import tempfile
import time
from datetime import datetime, timezone
from pathlib import Path

STATE_DIR = Path(os.environ.get("BENCH_STATE_DIR", os.path.expanduser("~/.local/state/bench-fabric")))
PREFLIGHT_DIR = STATE_DIR / "preflight"
CACHE_TTL_SEC = int(os.environ.get("BENCH_PREFLIGHT_TTL", "600"))
PROBE_TIMEOUT = int(os.environ.get("BENCH_PREFLIGHT_TIMEOUT", "30"))

PROBE_PROMPT = "Respond with the single word PING and nothing else."

KNOWN_AGENTS = ["claude", "codex", "opencode", "gemini", "copilot", "goose"]

FAILURE_PATTERNS = [
    (re.compile(r"no payment method|billing|insufficient.*credit|add a payment method", re.I), "E_BILLING"),
    (re.compile(r"validation error|extra inputs are not permitted|eager_input_streaming", re.I), "E_SCHEMA"),
    (re.compile(r"401|unauthori[sz]ed|invalid.*token|expired.*token|not.*logged", re.I), "E_AUTH"),
    (re.compile(r"rate.?limit|429|quota exceeded", re.I), "E_RATELIMIT"),
    (re.compile(r"model.*not.*found|unknown model|model_not_found", re.I), "E_MODEL"),
    (re.compile(r"timeout|connection.*refused|name.*resolution|dns", re.I), "E_NET"),
]


def _utc_now() -> str:
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def classify(text: str, exit_code: int) -> str:
    if exit_code == 0:
        return ""
    if not text:
        return "E_UNKNOWN"
    for pat, code in FAILURE_PATTERNS:
        if pat.search(text):
            return code
    return "E_UNKNOWN"


def cache_path(agent: str) -> Path:
    PREFLIGHT_DIR.mkdir(parents=True, exist_ok=True)
    return PREFLIGHT_DIR / f"{agent}.json"


def read_cache(agent: str) -> dict | None:
    p = cache_path(agent)
    if not p.exists():
        return None
    try:
        rec = json.loads(p.read_text(encoding="utf-8"))
    except (json.JSONDecodeError, OSError):
        return None
    age = time.time() - rec.get("_probe_epoch", 0)
    if age > CACHE_TTL_SEC:
        return None
    rec["_age_seconds"] = int(age)
    return rec


def write_cache(agent: str, rec: dict) -> None:
    p = cache_path(agent)
    p.write_text(json.dumps(rec, indent=2, sort_keys=True) + "\n", encoding="utf-8")


def probe_command(agent: str) -> list[str] | None:
    """Return the smallest-possible dispatch invocation for the agent.

    Returns None for agents without a known probe shape.
    """
    if not shutil.which(agent):
        return None
    if agent == "claude":
        return ["claude", "-p", PROBE_PROMPT, "--max-turns", "1"]
    if agent == "codex":
        return ["codex", "exec", PROBE_PROMPT, "--full-auto", "--skip-git-repo-check"]
    if agent == "opencode":
        return ["opencode", "run", PROBE_PROMPT]
    if agent == "gemini":
        return ["gemini", "-p", PROBE_PROMPT]
    if agent == "copilot":
        return ["copilot", "--prompt", PROBE_PROMPT]
    if agent == "goose":
        return ["goose", "run", "--text", PROBE_PROMPT]
    return None


def run_probe(agent: str) -> dict:
    """Run the probe and return a result record (not yet cached)."""
    rec = {
        "agent": agent,
        "ts": _utc_now(),
        "_probe_epoch": time.time(),
        "binary_present": bool(shutil.which(agent)),
    }
    cmd = probe_command(agent)
    if cmd is None:
        rec.update({
            "status": "red",
            "exit_code": None,
            "source_failure": "E_BIN_MISSING",
            "summary": f"{agent} binary not on PATH or no probe shape registered",
        })
        return rec

    with tempfile.TemporaryDirectory(prefix="bench-pf-") as tmp:
        try:
            proc = subprocess.run(
                cmd,
                capture_output=True,
                text=True,
                cwd=tmp,
                timeout=PROBE_TIMEOUT,
            )
        except subprocess.TimeoutExpired:
            rec.update({
                "status": "red",
                "exit_code": 124,
                "source_failure": "E_NET",
                "summary": f"probe timed out after {PROBE_TIMEOUT}s",
            })
            return rec
        except Exception as e:
            rec.update({
                "status": "red",
                "exit_code": None,
                "source_failure": "E_UNKNOWN",
                "summary": f"probe raised: {type(e).__name__}: {e}",
            })
            return rec

    rec["exit_code"] = proc.returncode
    if proc.returncode == 0:
        # Sanity: did the agent actually emit something resembling a response?
        out = (proc.stdout or "").strip()
        if not out:
            rec.update({"status": "yellow", "summary": "exit 0 but empty stdout"})
        else:
            rec.update({"status": "green", "summary": "ok"})
        return rec

    blob = (proc.stderr or "") + "\n" + (proc.stdout or "")
    source = classify(blob, proc.returncode)
    rec.update({
        "status": "red" if source in {"E_BILLING", "E_AUTH", "E_BIN_MISSING"} else "yellow",
        "source_failure": source,
        "summary": (proc.stderr or proc.stdout or "").strip()[-512:],
    })
    return rec


def status_to_exit(statuses: list[str]) -> int:
    if not statuses:
        return 3
    if any(s == "red" for s in statuses):
        return 2
    if any(s == "yellow" for s in statuses):
        return 1
    return 0


def render_table(records: list[dict]) -> str:
    lines = ["agent       status  source           summary"]
    for r in records:
        lines.append(
            "{agent:<11} {status:<7} {sf:<16} {sum}".format(
                agent=r["agent"],
                status=r.get("status", "?"),
                sf=r.get("source_failure", "—"),
                sum=(r.get("summary", "") or "")[:80].replace("\n", " "),
            )
        )
    return "\n".join(lines)


def main() -> int:
    p = argparse.ArgumentParser(prog="bench-preflight", description=__doc__.splitlines()[0])
    p.add_argument("agents", nargs="*", help="Specific agents (default: all known)")
    p.add_argument("--refresh", action="store_true", help="Ignore cache; re-probe")
    p.add_argument("--json", action="store_true", help="Emit JSON instead of a table")
    p.add_argument("--no-probe", action="store_true", help="Read cache only; do not probe")
    args = p.parse_args()

    targets = args.agents or KNOWN_AGENTS
    records: list[dict] = []
    for agent in targets:
        rec = None if args.refresh else read_cache(agent)
        if rec is None:
            if args.no_probe:
                rec = {
                    "agent": agent,
                    "status": "unknown",
                    "summary": "no cached probe; re-run without --no-probe",
                    "ts": _utc_now(),
                }
            else:
                rec = run_probe(agent)
                write_cache(agent, rec)
        records.append(rec)

    if args.json:
        print(json.dumps(records, indent=2, sort_keys=True))
    else:
        print(render_table(records))

    return status_to_exit([r.get("status", "?") for r in records])


if __name__ == "__main__":
    sys.exit(main())
