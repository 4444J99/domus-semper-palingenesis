#!/usr/bin/env python3
"""ark-build — assemble a chronological corpus of every user prompt across
Claude Code project scopes within a date window.

Usage:
    ark-build [--config PATH] [--since YYYY-MM-DD] [--until YYYY-MM-DD] [--out PATH]

Walks projects, extracts records where type=="user" and content is a real prompt,
deduplicates entries, then writes a navigable markdown artifact.
All logic is driven by a configuration schema to allow infinite repurposing.
"""
from __future__ import annotations

import argparse
import collections
import datetime as dt
import hashlib
import json
import os
import re
import sys
from pathlib import Path
from typing import Iterable, Any

# --- Default Configuration (The Multiversal Base) ---
DEFAULT_CONFIG = {
    "projects_root": str(Path.home() / ".claude" / "projects"),
    "projects_glob": "*",
    "since": "2026-04-19",
    "branding": {
        "title": "The Ark — Universal Prompt Corpus",
        "author_label": "Built by `ark-build` (Universal Framework)",
    },
    "synthetic_prefixes": [
        "<local-command-caveat>",
        "<command-name>",
        "<command-message>",
        "<system-reminder>",
        "Caveat: The messages below were generated",
    ],
    "wrapper_tags": [
        "local-command-caveat",
        "command-name",
        "command-message",
        "command-args",
        "system-reminder",
        "user-prompt-submit-hook",
    ],
    "themes": [
        # Example themes - should be overridden in local config
        {"name": "System / Organ", "keywords": ["organvm", "organ", "system"]},
        {"name": "Planning / Execution", "keywords": ["plan", "planning", "task"]},
    ],
}

def load_config(path: str | None = None) -> dict[str, Any]:
    config = DEFAULT_CONFIG.copy()
    if path:
        p = Path(path).expanduser()
        if p.exists():
            with p.open() as f:
                # Basic JSON loader for simplicity, could be YAML
                local = json.load(f)
                # Deep merge branding and themes if present
                if "branding" in local:
                    config["branding"].update(local["branding"])
                if "themes" in local:
                    config["themes"] = local["themes"]
                # Update the rest
                for k, v in local.items():
                    if k not in ["branding", "themes"]:
                        config[k] = v
    return config

def get_wrapper_re(tags: list[str]) -> re.Pattern:
    pattern = r"<(" + "|".join(re.escape(t) for t in tags) + r")[^>]*>.*?</\1>"
    return re.compile(pattern, re.DOTALL)

def extract_user_text(record: dict, synthetic_prefixes: list[str], wrapper_re: re.Pattern) -> str | None:
    msg = record.get("message")
    if not isinstance(msg, dict):
        return None
    content = msg.get("content")
    text_chunks: list[str] = []
    if isinstance(content, str):
        text_chunks.append(content)
    elif isinstance(content, list):
        for c in content:
            if not isinstance(c, dict):
                continue
            if c.get("type") == "tool_result":
                return None
            if c.get("type") == "text":
                text_chunks.append(c.get("text", ""))
    if not text_chunks:
        return None
    text = "\n".join(text_chunks).strip()
    if not text:
        return None
    
    stripped = wrapper_re.sub("", text).strip()
    if not stripped:
        return None
    
    if any(text.lstrip().startswith(p) for p in synthetic_prefixes) and len(stripped) < 30:
        return None
    return text

def parse_iso(ts: str) -> dt.datetime | None:
    if not ts:
        return None
    try:
        return dt.datetime.fromisoformat(ts.replace("Z", "+00:00"))
    except Exception:
        return None

def scope_label(project_dir: Path) -> str:
    name = project_dir.name
    if name.startswith("-"):
        return "/" + name[1:].replace("-", "/")
    return name

def iter_prompts(config: dict[str, Any], since: dt.datetime, until: dt.datetime) -> Iterable[dict]:
    seen_uuids: set[str] = set()
    seen_hashes: set[str] = set()
    wrapper_re = get_wrapper_re(config["wrapper_tags"])
    projects_root = Path(config["projects_root"]).expanduser()

    for project_dir in sorted(projects_root.glob(config["projects_glob"])):
        if not project_dir.is_dir():
            continue
        for jsonl in sorted(project_dir.glob("*.jsonl")):
            try:
                mtime = dt.datetime.fromtimestamp(jsonl.stat().st_mtime, tz=dt.timezone.utc)
            except OSError:
                continue
            if mtime < since:
                continue
            session_id = jsonl.stem
            scope = scope_label(project_dir)
            try:
                with jsonl.open() as f:
                    for line_no, line in enumerate(f, 1):
                        try:
                            rec = json.loads(line)
                        except Exception:
                            continue
                        if rec.get("type") != "user":
                            continue

                        uuid = rec.get("uuid")
                        if uuid and uuid in seen_uuids:
                            continue

                        ts = parse_iso(rec.get("timestamp", ""))
                        if ts is None or ts < since or ts > until:
                            continue

                        text = extract_user_text(rec, config["synthetic_prefixes"], wrapper_re)
                        if text is None:
                            continue

                        text_hash = hashlib.sha256(text.encode()).hexdigest()
                        if text_hash in seen_hashes:
                            continue

                        if uuid:
                            seen_uuids.add(uuid)
                        seen_hashes.add(text_hash)

                        yield {
                            "ts": ts,
                            "scope": scope,
                            "session_id": session_id,
                            "text": text,
                            "uuid": uuid or "",
                            "cwd": rec.get("cwd", ""),
                            "git_branch": rec.get("gitBranch", ""),
                            "file": str(jsonl),
                            "line": line_no,
                        }
            except OSError:
                continue

def first_clause(text: str, wrapper_re: re.Pattern, n: int = 80) -> str:
    cleaned = wrapper_re.sub("", text).strip()
    cleaned = re.sub(r"\s+", " ", cleaned)
    if not cleaned:
        cleaned = text.strip().splitlines()[0] if text.strip() else "(empty)"
    return cleaned[:n] + ("…" if len(cleaned) > n else "")

def render_ark(
    config: dict[str, Any],
    prompts: list[dict],
    since: dt.datetime,
    until: dt.datetime,
    max_prompt_bytes: int | None = None,
) -> str:
    window_days = (until.date() - since.date()).days + 1
    branding = config["branding"]
    wrapper_re = get_wrapper_re(config["wrapper_tags"])

    out: list[str] = []
    out.append(f"# {branding['title']}")
    out.append("")
    out.append(f"**Window:** {since.date()} → {until.date()} ({window_days} days)  ")
    out.append(f"**Total prompts:** {len(prompts)} (deduplicated)  ")
    if max_prompt_bytes is not None:
        truncated_count = sum(1 for p in prompts if len(p["text"]) > max_prompt_bytes)
        out.append(f"**Distillation:** prompts >{max_prompt_bytes:,} bytes shown as stubs ({truncated_count} truncated) to surface human signal.  ")
    out.append(f"**Generated:** {dt.datetime.now(dt.timezone.utc).isoformat(timespec='seconds')}  ")
    out.append(f"**Branding:** {branding['author_label']}  ")
    out.append("")
    out.append("---")
    out.append("")
    out.append("## 1. Index")
    out.append("")
    by_date = collections.defaultdict(list)
    for p in prompts:
        by_date[p["ts"].date()].append(p)
    for date in sorted(by_date.keys()):
        day_prompts = by_date[date]
        out.append(f"### {date.isoformat()} — {len(day_prompts)} prompts")
        out.append("")
        out.append("| Time (UTC) | Scope | Length | Opening clause |")
        out.append("|---|---|---:|---|")
        for p in day_prompts:
            time_s = p["ts"].strftime("%H:%M")
            scope_short = p["scope"].replace(str(Path.home()), "~").replace("/Workspace/", "/W/")
            length = len(p["text"])
            clause = first_clause(p["text"], wrapper_re, 70).replace("|", "\\|")
            out.append(f"| {time_s} | `{scope_short}` | {length} | {clause} |")
        out.append("")

    out.append("---")
    out.append("")
    out.append("## 2. Through-lines")
    out.append("")
    out.append("| Theme | Prompts | Sample timestamps |")
    out.append("|---|---:|---|")
    for theme in config["themes"]:
        name = theme["name"]
        keywords = theme["keywords"]
        matches = [p for p in prompts if any(k.lower() in p["text"].lower() for k in keywords)]
        if not matches:
            continue
        sample_ts = ", ".join(m["ts"].strftime("%m-%d %H:%M") for m in matches[:3])
        if len(matches) > 3:
            sample_ts += f", … (+{len(matches)-3} more)"
        out.append(f"| {name} | {len(matches)} | {sample_ts} |")
    out.append("")

    out.append("---")
    out.append("")
    out.append("## 3. Full chronology")
    out.append("")
    for p in prompts:
        ts_s = p["ts"].strftime("%Y-%m-%d %H:%M:%S UTC")
        scope_short = p["scope"].replace(str(Path.home()), "~")
        sid_short = p["session_id"][:8]
        out.append(f"### {ts_s} · `{scope_short}` · `{sid_short}`")
        out.append("")
        text = p["text"]
        if max_prompt_bytes is not None and len(text) > max_prompt_bytes:
            head = text[:max_prompt_bytes]
            fence = "```"
            while fence in head: fence += "`"
            out.append(fence)
            out.append(head)
            out.append(fence)
            out.append("")
            out.append(f"> **[truncated]** prompt is {len(text):,} bytes total — first {max_prompt_bytes:,} shown above. Full text in `{p['file']}` line {p['line']}.")
            out.append("")
        else:
            fence = "```"
            while fence in text: fence += "`"
            out.append(fence)
            out.append(text)
            out.append(fence)
            out.append("")

    return "\n".join(out)

def main() -> int:
    ap = argparse.ArgumentParser(description=__doc__)
    ap.add_argument("--config", help="path to config JSON")
    ap.add_argument("--since", help="ISO date (e.g. 2026-04-19)")
    ap.add_argument("--until", help="ISO date (default: now)")
    ap.add_argument("--out", help="output markdown path (default: stdout)")
    ap.add_argument("--max-prompt-bytes", type=int, help="truncate prompts longer than this")
    args = ap.parse_args()

    config = load_config(args.config)
    since_str = args.since or config["since"]
    since = dt.datetime.fromisoformat(since_str).replace(tzinfo=dt.timezone.utc)
    until = dt.datetime.fromisoformat(args.until).replace(tzinfo=dt.timezone.utc) if args.until else dt.datetime.now(dt.timezone.utc)

    print(f"[ark-build] window: {since.isoformat()} → {until.isoformat()}", file=sys.stderr)
    prompts = sorted(iter_prompts(config, since, until), key=lambda p: p["ts"])
    print(f"[ark-build] extracted {len(prompts)} real user prompts", file=sys.stderr)

    body = render_ark(config, prompts, since, until, max_prompt_bytes=args.max_prompt_bytes)
    
    if args.out:
        out_path = Path(args.out).expanduser()
        out_path.parent.mkdir(parents=True, exist_ok=True)
        out_path.write_text(body)
        print(f"[ark-build] wrote {out_path} ({len(body)} bytes)", file=sys.stderr)
    else:
        sys.stdout.write(body)

    return 0

if __name__ == "__main__":
    sys.exit(main())
