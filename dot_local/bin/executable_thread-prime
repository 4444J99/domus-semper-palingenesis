#!/usr/bin/env zsh
# thread-prime — emit a compact (≤2KB) primer for a thread, replacing recursive paste (F1 cure).
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "usage: thread-prime <thread-id>" >&2
  exit 1
fi

THREAD_ID="$1"
SESSIONS_DIR="${HOME}/.claude/sessions"
STATE_FILE="${SESSIONS_DIR}/${THREAD_ID}/state.json"

if ! command -v jq >/dev/null 2>&1; then
  echo "thread-prime: jq is required (brew install jq)" >&2
  exit 1
fi

if [[ ! -f "$STATE_FILE" ]]; then
  echo "thread-prime: no state.json at $STATE_FILE" >&2
  echo "hint: run thread-init-legacy to populate state for legacy threads" >&2
  exit 1
fi

# Build primer; hard-cap at 2KB to enforce the F1-cure invariant.
{
  jq -r '
    "═══ THREAD PRIMER ═══",
    "id:             \(.thread_id)",
    "name:           \(.descriptive_name // "(unnamed)")",
    "surface:        \(.surface // "?")",
    "classification: \(.classification // "?")",
    "state:          \(.state // "?")",
    "opened:         \(.opened_at // "?")",
    "last_touched:   \(.last_touched_at // "?")",
    (if .closed_at then "closed:         \(.closed_at)" else empty end),
    "",
    "─── pending decisions ───",
    (if (.pending_decisions // [] | length) > 0
      then (.pending_decisions[:3] | to_entries | map("  \(.key + 1). \(.value)") | join("\n"))
      else "  (none)"
    end),
    "",
    "─── primer ───",
    (.primer // "  (no primer captured — close the thread to seed one)"),
    "",
    "═══ END PRIMER (F1 cure: this replaces recursive paste) ═══"
  ' "$STATE_FILE"
} | head -c 2048
echo
