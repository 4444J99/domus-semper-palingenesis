#!/usr/bin/env python3
"""insights-list — chronological listing of insights snapshots."""
from __future__ import annotations
import json
import pathlib
import sys

SNAPDIR = pathlib.Path.home() / ".claude" / "usage-data" / "snapshots"


def main() -> int:
    if not SNAPDIR.is_dir():
        sys.exit(f"insights-list: no snapshots dir: {SNAPDIR}")
    snaps = sorted(d for d in SNAPDIR.glob("*") if d.is_dir() and (d / "manifest.json").exists())
    if not snaps:
        print("(no snapshots)")
        return 0
    for d in snaps:
        m = json.loads((d / "manifest.json").read_text())
        s = m.get("stats", {})
        w = m.get("window", {})
        sa = s.get("sessions_analyzed", "?")
        st = s.get("sessions_total", "?")
        msg = s.get("messages", "?")
        com = s.get("commits", "?")
        win = (
            f"{w.get('start','?')} → {w.get('end','?')} ({w.get('days','?')}d)"
            if w
            else "(no window)"
        )
        print(
            f"{d.name}  {sa}/{st} sessions · {msg} msgs · {com} commits  | {win}"
        )
    return 0


if __name__ == "__main__":
    sys.exit(main())
