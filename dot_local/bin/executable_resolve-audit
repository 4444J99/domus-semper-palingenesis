#!/usr/bin/env bash
set -euo pipefail

# resolve-audit — Find deployed config paths that bypass the resolver.
#
# Usage:
#   resolve-audit              # full report
#   resolve-audit --count      # just the count
#   resolve-audit --hook       # JSON for session-start hook

MODE="full"
[[ "${1:-}" == "--count" ]] && MODE="count"
[[ "${1:-}" == "--hook" ]] && MODE="hook"

# The tools legitimately store absolute paths in project trust maps and
# GitHub repo lookup caches. Those are not executable bypasses. This audit
# reports executable/config fields that should route through bootstrap launchers.
DEPLOYED_HITS="$(python3 - <<'PY'
import json
import re
from pathlib import Path

home = Path.home()
pattern = re.compile(
    r"(/Users/[^/]*/Workspace/[a-z]|organvm-iv-taxis|organvm-i-theoria|"
    r"organvm-ii-poiesis|organvm-iii-ergon|organvm-v-logos|"
    r"organvm-vi-koinonia|organvm-vii-kerygma)"
)


def rel(path: Path) -> str:
    try:
        return str(path.relative_to(home))
    except ValueError:
        return str(path)


def emit_text_hits(path: Path, *, skip_codex_projects: bool = False) -> None:
    if not path.exists():
        return
    in_codex_projects = False
    for line_no, line in enumerate(path.read_text(errors="replace").splitlines(), 1):
        stripped = line.strip()
        if skip_codex_projects and stripped.startswith("[projects"):
            in_codex_projects = True
        elif skip_codex_projects and stripped.startswith("[") and not stripped.startswith("[projects"):
            in_codex_projects = False
        if in_codex_projects:
            continue
        if pattern.search(line):
            print(f"{rel(path)}:{line_no}:{line}")


def walk_mcp(value, path: tuple[str, ...] = ()) -> None:
    if isinstance(value, dict):
        for key, child in value.items():
            walk_mcp(child, path + (str(key),))
    elif isinstance(value, list):
        for idx, child in enumerate(value):
            walk_mcp(child, path + (str(idx),))
    elif isinstance(value, str) and pattern.search(value):
        print(f".claude.json:mcpServers.{'.'.join(path)}:{value}")


claude_json = home / ".claude.json"
if claude_json.exists():
    data = json.loads(claude_json.read_text())
    walk_mcp(data.get("mcpServers", {}))

emit_text_hits(home / ".claude" / "settings.json")
emit_text_hits(home / ".local" / "share" / "codex" / "config.toml", skip_codex_projects=True)
PY
)"

# ── Count ──
ALL_HITS="${DEPLOYED_HITS}"
if [[ -z "$ALL_HITS" ]]; then
  COUNT=0
else
  COUNT=$(echo "$ALL_HITS" | grep -c '.' || true)
fi

# ── Output ──
if [[ "$MODE" == "count" ]]; then
  echo "$COUNT"
  exit $((COUNT > 0 ? 1 : 0))
fi

if [[ "$MODE" == "hook" ]]; then
  if [[ $COUNT -eq 0 ]]; then
    echo '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"RESOLVER AUDIT: 0 violations. All configs route through the resolver."}}'
  else
    echo "{\"hookSpecificOutput\":{\"hookEventName\":\"SessionStart\",\"additionalContext\":\"RESOLVER AUDIT: ${COUNT} hardcoded path violations. Do NOT fix paths — connect to resolve-bootstrap instead. Run: resolve-audit\"}}"
  fi
  exit 0
fi

# Full report
if [[ $COUNT -eq 0 ]]; then
  echo "No hardcoded path violations found."
  exit 0
fi

echo "RESOLVER AUDIT: ${COUNT} hardcoded path violations"
echo "=================================================="
echo ""
echo "Do NOT fix paths. Connect them to resolve-bootstrap instead."
echo ""

if [[ -n "$DEPLOYED_HITS" ]]; then
  echo "[DEPLOYED CONFIGS]"
  echo "$DEPLOYED_HITS"
fi

exit 1
