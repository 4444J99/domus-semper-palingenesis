models:
  - title: Claude Sonnet
    provider: anthropic
    model: claude-sonnet-4-20250514
    apiKey: "${ANTHROPIC_API_KEY}"

mcpServers:
  - name: github
    command: /opt/homebrew/bin/github-mcp-server
    args: ["stdio"]
    env:
      GITHUB_PERSONAL_ACCESS_TOKEN: "{{ if and (and (hasKey . "is_ci") (and (hasKey . "is_ci") (not .is_ci))) (lookPath "op") }}{{ onepasswordRead "op://Personal/master-org-token-110525/token" }}{{ else }}CI_REDACTED{{ end }}"
  - name: jupyter
    command: jupyter-mcp-server
  - name: serena
    command: uvx
    args: ["--from", "git+https://github.com/4444J99/serena", "serena", "start-mcp-server", "--context", "ide"]
