model = "gpt-5.4"
model_reasoning_effort = "xhigh"
personality = "pragmatic"
sandbox_mode = "danger-full-access"
service_tier = "fast"

[mcp_servers]
[mcp_servers.github]
command = '/opt/homebrew/bin/github-mcp-server'
args = ['stdio']
startup_timeout_sec = 30

[mcp_servers.conductor]
command = '{{ .chezmoi.homeDir }}/.local/bin/organvm-conductor-mcp'
args = []
startup_timeout_sec = 30

[mcp_servers.voice-scorer]
command = '{{ .chezmoi.homeDir }}/.local/bin/organvm-voice-scorer-mcp'
args = []

[notice]
hide_full_access_warning = true
'hide_gpt-5.1-codex-max_migration_prompt' = true

[notice.model_migrations]
"gpt-5.1-codex-max" = "gpt-5.2-codex"
"gpt-5.1-codex-mini" = "gpt-5.2-codex"
"gpt-5.3-codex" = "gpt-5.4"

