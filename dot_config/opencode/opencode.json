{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "github": {
      "type": "local",
      "command": ["/opt/homebrew/bin/github-mcp-server", "stdio"],
      "enabled": true
    },
    "serena": {
      "type": "local",
      "command": ["uvx", "--from", "git+https://github.com/4444J99/serena", "serena", "start-mcp-server"],
      "enabled": true
    },
    "jupyter": {
      "type": "local",
      "command": ["jupyter-mcp-server"],
      "enabled": true
    }
  }
}
