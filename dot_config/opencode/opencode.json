{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "MCP_DOCKER": {
      "type": "local",
      "command": ["docker", "mcp", "gateway", "run"],
      "enabled": true
    },
    "serena": {
      "type": "local",
      "command": ["uvx", "--from", "git+https://github.com/4444J99/serena", "serena", "start-mcp-server"],
      "enabled": true
    },
    "jupyter": {
      "type": "local",
      "command": ["jupyter-mcp-server"],
      "enabled": true
    }
  }
}
