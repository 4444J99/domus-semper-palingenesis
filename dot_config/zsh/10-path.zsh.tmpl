# ─────────────────────────────────────────────────────────────────────────────
# PATH Configuration (templated for OS/arch portability)
# ─────────────────────────────────────────────────────────────────────────────

# Deduplicate PATH entries from the start (prevents accumulation across sources)
typeset -U path PATH fpath FPATH

{{- if eq .chezmoi.os "darwin" }}
{{- if eq .chezmoi.arch "arm64" }}
# macOS ARM64 (Apple Silicon) — Homebrew
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:$PATH"
export PATH="/opt/homebrew/opt/file-formula/bin:$PATH"
{{- else }}
# macOS Intel — Homebrew
export PATH="/usr/local/bin:/usr/local/sbin:$PATH"
{{- end }}
{{- else if eq .chezmoi.os "linux" }}
# Linux Homebrew
if [[ -d "/home/linuxbrew/.linuxbrew/bin" ]]; then
  export PATH="/home/linuxbrew/.linuxbrew/bin:$PATH"
fi
{{- end }}

{{- if eq .chezmoi.os "darwin" }}
# Ruby (Homebrew — dynamic gem version, no hardcoded path)
export PATH="/opt/homebrew/opt/ruby/bin:$PATH"
_ruby_gem_dir=(/opt/homebrew/lib/ruby/gems/*/bin(N[1]))
[[ -n "$_ruby_gem_dir" ]] && export PATH="$_ruby_gem_dir:$PATH"
unset _ruby_gem_dir
export LDFLAGS="-L/opt/homebrew/opt/ruby/lib"
export CPPFLAGS="-I/opt/homebrew/opt/ruby/include"
export PKG_CONFIG_PATH="/opt/homebrew/opt/ruby/lib/pkgconfig"
{{- end }}

# Go (GOPATH defined in 15-env.zsh; fallback mirrors that definition)
export PATH="${GOPATH:-${XDG_DATA_HOME:-$HOME/.local/share}/go}/bin:$PATH"

# Rust (rustup toolchain)
export PATH="${CARGO_HOME:-$HOME/.local/share/cargo}/bin:$PATH"

# npm global bin (prefix set in npmrc → XDG_DATA_HOME/npm)
export PATH="${XDG_DATA_HOME:-$HOME/.local/share}/npm/bin:$PATH"

# pipx / uv tool installs
export PATH="$HOME/.local/bin:$PATH"

# Agent harness scripts (resolved at template time — no runtime var dependency)
export PATH="{{ .chezmoi.sourceDir }}/_agents/bin:$PATH"

# Android platform-tools
[[ -d "${ANDROID_HOME:-}/platform-tools" ]] && export PATH="$PATH:$ANDROID_HOME/platform-tools"

{{- if eq .chezmoi.os "darwin" }}
# Python (Homebrew — follows latest via python@3 symlink)
export PATH="/opt/homebrew/opt/python@3/libexec/bin:$PATH"

# Toolchains (External Volume — macOS only, graceful if not mounted)
[[ -d "/Volumes/4444-iivii/ivi374forivi3ivi3/toolchains/bin" ]] && \
  export PATH="$PATH:/Volumes/4444-iivii/ivi374forivi3ivi3/toolchains/bin"
{{- end }}
