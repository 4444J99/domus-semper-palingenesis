#!/usr/bin/env zsh
# XDG Base Directories (set earliest for all tools)
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_STATE_HOME="$HOME/.local/state"
export XDG_CACHE_HOME="$HOME/.cache"

# Disable macOS Terminal session restore (overrides HISTFILE with per-session files)
export SHELL_SESSIONS_DISABLE=1

# Redirect zsh config to XDG location
export ZDOTDIR="$XDG_CONFIG_HOME/zsh"

# History: override /etc/zshrc default (which puts it in ZDOTDIR)
export HISTFILE="$XDG_STATE_HOME/zsh/history"
export HISTSIZE=50000
export SAVEHIST=50000

# ── ORGANVM workspace ──
export ORGANVM_WORKSPACE_DIR="$HOME/Workspace"
export ORGANVM_CORPUS_DIR="$ORGANVM_WORKSPACE_DIR/meta-organvm/organvm-corpvs-testamentvm"

# ── Organ → GitHub org mapping ──
export ORG_I="organvm-i-theoria"
export ORG_II="organvm-ii-poiesis"
export ORG_III="organvm-iii-ergon"
export ORG_IV="organvm-iv-taxis"
export ORG_V="organvm-v-logos"
export ORG_VI="organvm-vi-koinonia"
export ORG_VII="organvm-vii-kerygma"
export ORG_META="meta-organvm"

# ── Personal namespaces ──
export ORG_LIMINAL="4444j99"
export ORG_LIMINAL_ALT="4444jpp"

# ── Account identity ──
export GITHUB_PRIMARY="4444J99"
export GITHUB_SECONDARY="4444JPP"
export PAGER=cat
export CLAUDE_INTERACTIVE=0
export CLAUDE_CODE_MAX_OUTPUT_TOKENS=128000
