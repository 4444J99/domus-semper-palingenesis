#!/usr/bin/env bash
# Ensure XDG symlinks for apps that insist on ~/.<app>
# Idempotent: safe to run on every chezmoi apply
set -euo pipefail

apps=(
  antigravity
  blender_ext
  cagent
  claude-server-commander
  cline
  cloudbase-mcp
  codex
  copilot
  cursor
  dropbox
  dropbox_bi
  gemini
  jules
  kimi
  mcp-auth
  metasystem
  my-father-mother
  ollama
  playwright-mcp
  render
  serena
  venvs
  vscode
  vscode-insiders
  warp
)

changed=0

for app in "${apps[@]}"; do
  target="$HOME/.local/share/$app"
  link="$HOME/.$app"

  # Already a correct symlink — skip
  if [[ -L "$link" && "$(readlink "$link")" == "$target" ]]; then
    continue
  fi

  # Ensure target directory exists
  mkdir -p "$target"

  # Real directory exists — merge contents then remove
  # --ignore-errors: apps like Dropbox have ephemeral internal files
  if [[ -d "$link" && ! -L "$link" ]]; then
    rsync -a --ignore-errors "$link/" "$target/" || true
    rm -rf "$link"
  fi

  # Remove stale symlink or file
  [[ -e "$link" || -L "$link" ]] && rm -f "$link"

  ln -s "$target" "$link"
  ((changed++)) || true
done

if ((changed > 0)); then
  echo "🔗 Created/updated $changed XDG symlinks"
fi
