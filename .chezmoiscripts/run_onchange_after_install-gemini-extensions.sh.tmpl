#!/usr/bin/env bash
set -euo pipefail

# Gemini CLI extension installer
# chezmoi:template:hash
# {{ "gemini-extensions-v3" }}

if ! command -v gemini &>/dev/null; then
  echo "⚠️  Gemini CLI not found, skipping extensions"
  exit 0
fi

# Extensions from GitHub repos (gemini extensions install <url>)
github_extensions=(
  # Core MCP servers
  "https://github.com/ChromeDevTools/chrome-devtools-mcp"               # chrome-devtools: live Chrome debugging, Lighthouse
  "https://github.com/cloud-aspect/doc-indexer"                         # doc-indexer: documentation indexing
  "https://github.com/swissspidy/extension-browser"                     # extension-browser: browse/install extensions
  "https://github.com/qodo-ai/open-aware"                              # open-aware: OSS research
  "https://github.com/Flux159/mcp-game-asset-gen"                       # asset-gen: image/3D generation

  # Google Cloud
  "https://github.com/gemini-cli-extensions/gcloud"                     # gcloud CLI
  "https://github.com/GoogleCloudPlatform/gke-mcp"                      # GKE cluster management
  "https://github.com/googleworkspace/developer-tools"                  # Workspace API docs

  # AI integration
  "https://github.com/gemini-cli-extensions/jules"                      # Jules task delegation

  # Workflow commands
  "https://github.com/paufortiana/geminicli-git-tools-extension"        # /git-commit:write, /git-pr:draft
  "https://github.com/gemini-cli-extensions/code-review"                # /code-review, /pr-code-review
  "https://github.com/abagames/slash-criticalthink"                     # /criticalthink
)

installed=$(gemini extensions list 2>/dev/null || echo "")

for url in "${github_extensions[@]}"; do
  name="${url##*/}"
  if ! echo "$installed" | grep -qi "$name"; then
    echo "Installing Gemini extension: $name"
    gemini extensions install "$url" 2>/dev/null || echo "⚠️  Failed to install $name"
  fi
done

# Local extensions (from ORGANVM skills build)
local_extensions=(
  "/Users/4jp/Workspace/organvm-iv-taxis/a-i--skills/.build/extensions/gemini/document-skills"
  "/Users/4jp/Workspace/organvm-iv-taxis/a-i--skills/.build/extensions/gemini/example-skills"
)

for path in "${local_extensions[@]}"; do
  name="$(basename "$path")"
  if [ -d "$path" ] && ! echo "$installed" | grep -qi "$name"; then
    echo "Installing local Gemini extension: $name"
    gemini extensions install "$path" 2>/dev/null || echo "⚠️  Failed to install $name (path may not exist yet)"
  fi
done

echo "✅ Gemini extensions ready (14 extensions)"
