#!/usr/bin/env bash
set -euo pipefail

# Gemini CLI extension installer
# chezmoi:template:hash
# {{ "gemini-extensions-v4" }}

if ! command -v gemini &>/dev/null; then
  echo "⚠️  Gemini CLI not found, skipping extensions"
  exit 0
fi

EXTENSIONS_DIR="${HOME}/.gemini/extensions"

# Map: directory-name|install-url
# Check by directory existence rather than parsing `gemini extensions list`
github_extensions=(
  # Core MCP servers
  "chrome-devtools-mcp|https://github.com/ChromeDevTools/chrome-devtools-mcp"
  "doc-indexer|https://github.com/cloud-aspect/doc-indexer"
  "extension-browser|https://github.com/swissspidy/extension-browser"
  "open-aware|https://github.com/qodo-ai/open-aware"
  "mcp-game-asset-gen|https://github.com/Flux159/mcp-game-asset-gen"

  # Google Cloud
  "gcloud|https://github.com/gemini-cli-extensions/gcloud"
  "gke-mcp|https://github.com/GoogleCloudPlatform/gke-mcp"
  "google-workspace-developer-tools|https://github.com/googleworkspace/developer-tools"

  # AI integration
  "gemini-cli-jules|https://github.com/gemini-cli-extensions/jules"

  # Workflow commands
  "git-tools|https://github.com/paufortiana/geminicli-git-tools-extension"
  "code-review|https://github.com/gemini-cli-extensions/code-review"
  "criticalthink|https://github.com/abagames/slash-criticalthink"
)

for entry in "${github_extensions[@]}"; do
  dir_name="${entry%%|*}"
  url="${entry##*|}"
  if [ ! -d "${EXTENSIONS_DIR}/${dir_name}" ]; then
    echo "Installing Gemini extension: ${dir_name}"
    gemini extensions install "$url" 2>/dev/null || echo "⚠️  Failed to install ${dir_name}"
  fi
done

# Local extensions (from ORGANVM skills build)
local_extensions=(
  "document-skills|{{ .chezmoi.homeDir }}/Workspace/{{ .organvm_dir }}/{{ .skills_dir }}/distributions/extensions/gemini/document-skills"
  "example-skills|{{ .chezmoi.homeDir }}/Workspace/{{ .organvm_dir }}/{{ .skills_dir }}/distributions/extensions/gemini/example-skills"
)

for entry in "${local_extensions[@]}"; do
  dir_name="${entry%%|*}"
  path="${entry##*|}"
  if [ ! -d "${EXTENSIONS_DIR}/${dir_name}" ] && [ -d "$path" ]; then
    echo "Installing local Gemini extension: ${dir_name}"
    gemini extensions install "$path" 2>/dev/null || echo "⚠️  Failed to install ${dir_name}"
  fi
done

echo "✅ Gemini extensions ready"
