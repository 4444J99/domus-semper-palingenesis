#!/usr/bin/env bash
# LaunchAgent management — ALL AGENTS REMOVED 2026-04-22
# Per user directive: nothing runs automatically. All former agents
# converted to on-demand CLI commands via `domus refresh <task>`.
# This script only ensures state directories exist.

{{- if eq .chezmoi.os "darwin" }}

set -euo pipefail

mkdir -p "${HOME}/.local/state/domus"

echo "LaunchAgents: none loaded (all removed 2026-04-22)."
echo "Use 'domus refresh <cce|memory|soak|archive>' for on-demand execution."

{{- else }}
echo "Skipping launchd setup (not macOS)"
{{- end }}
